generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ─── AUTH ─────────────────────────────────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  role         String   @default("STAFF") // OWNER | MANAGER | STAFF
  phone        String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("users")
}

// ─── CLIENTS ──────────────────────────────────────────────────────────────────

model Client {
  id            String   @id @default(cuid())
  name          String
  phone         String   @unique
  email         String?
  dateOfBirth   DateTime?
  address       String?
  loyaltyPoints Int      @default(0)
  loyaltyTier   String   @default("Bronze") // Bronze | Silver | Gold | Platinum
  notes         String?
  tags          String   @default("") // comma-separated
  isActive      Boolean  @default(true)
  lastVisitAt   DateTime?
  totalVisits   Int      @default(0)
  totalSpent    Float    @default(0)
  preferredStaff String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  appointments  Appointment[]
  invoices      Invoice[]

  @@map("clients")
}

// ─── SERVICES ─────────────────────────────────────────────────────────────────

model Service {
  id          String   @id @default(cuid())
  name        String
  category    String
  description String?
  duration    Int
  price       Float
  isActive    Boolean  @default(true)
  isPopular   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  appointmentServices AppointmentService[]
  invoiceItems        InvoiceItem[]

  @@map("services")
}

// ─── STAFF ────────────────────────────────────────────────────────────────────

model Staff {
  id             String   @id @default(cuid())
  name           String
  role           String
  phone          String?
  email          String?
  specialties    String   @default("") // comma-separated
  rating         Float    @default(5.0)
  commissionRate Float    @default(30)
  isActive       Boolean  @default(true)
  isAvailable    Boolean  @default(true)
  color          String   @default("#E5E7EB")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  appointments Appointment[]

  @@map("staff")
}

// ─── ROOMS ────────────────────────────────────────────────────────────────────

model Room {
  id       String  @id @default(cuid())
  name     String
  isActive Boolean @default(true)

  appointments Appointment[]

  @@map("rooms")
}

// ─── APPOINTMENTS ─────────────────────────────────────────────────────────────

model Appointment {
  id            String   @id @default(cuid())
  clientId      String
  staffId       String
  roomId        String?
  date          String   // YYYY-MM-DD
  startTime     String   // HH:MM
  endTime       String   // HH:MM
  duration      Int
  totalPrice    Float
  status        String   @default("pending")
  // confirmed | pending | in-progress | completed | cancelled | no-show
  paymentStatus String   @default("pending")
  // pending | partial | paid | refunded
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  client   Client  @relation(fields: [clientId], references: [id])
  staff    Staff   @relation(fields: [staffId], references: [id])
  room     Room?   @relation(fields: [roomId], references: [id])
  services AppointmentService[]
  invoice  Invoice?
  automationLogs AutomationLog[]

  @@map("appointments")
}

model AppointmentService {
  id            String @id @default(cuid())
  appointmentId String
  serviceId     String
  price         Float
  duration      Int

  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  service     Service     @relation(fields: [serviceId], references: [id])

  @@map("appointment_services")
}

// ─── INVOICES ─────────────────────────────────────────────────────────────────

model Invoice {
  id            String   @id @default(cuid())
  clientId      String
  appointmentId String?  @unique
  invoiceNumber String   @unique
  subtotal      Float
  discountPct   Float    @default(0)
  discountAmt   Float    @default(0)
  total         Float
  status        String   @default("draft") // draft | paid | partial | overdue
  paymentMethod String?  // cash | momo | card | transfer
  paidAt        DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  client      Client   @relation(fields: [clientId], references: [id])
  appointment Appointment? @relation(fields: [appointmentId], references: [id])
  items       InvoiceItem[]

  @@map("invoices")
}

model InvoiceItem {
  id          String @id @default(cuid())
  invoiceId   String
  serviceId   String?
  description String
  quantity    Int    @default(1)
  unitPrice   Float
  total       Float

  invoice Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  service Service? @relation(fields: [serviceId], references: [id])

  @@map("invoice_items")
}

// ─── AUTOMATIONS ──────────────────────────────────────────────────────────────

model Automation {
  id              String  @id @default(cuid())
  name            String
  description     String?
  trigger         String
  // before_appointment | after_appointment | birthday | no_visit
  // no_show | payment | loyalty_upgrade | new_client | review_request
  channel         String  // sms | whatsapp | email
  isActive        Boolean @default(true)
  delayMinutes    Int     @default(0)  // +ve = after, -ve = before
  conditionJson   String  @default("{}") // JSON string: extra conditions
  messageTemplate String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  logs AutomationLog[]

  @@map("automations")
}

model AutomationLog {
  id            String   @id @default(cuid())
  automationId  String
  appointmentId String?
  clientId      String?
  recipient     String   // phone or email
  message       String
  channel       String
  status        String   @default("pending") // pending | sent | failed | skipped
  error         String?
  sentAt        DateTime?
  createdAt     DateTime @default(now())

  automation  Automation  @relation(fields: [automationId], references: [id])
  appointment Appointment? @relation(fields: [appointmentId], references: [id])

  @@map("automation_logs")
}
