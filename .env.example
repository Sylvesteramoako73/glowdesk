# ── Firebase Client SDK (public — safe to expose) ─────────────────────────────
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ── Firebase Admin SDK (server-only — NEVER expose publicly) ──────────────────
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=          # Paste full key including -----BEGIN/END----- lines

# ── Twilio — SMS + WhatsApp reminders ─────────────────────────────────────────
TWILIO_ACCOUNT_SID=            # ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=
TWILIO_FROM_SMS=               # +1234567890
TWILIO_FROM_WHATSAPP=          # whatsapp:+14155238886

# ── Google Calendar OAuth ─────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=              # Google Cloud Console → APIs & Services → Credentials
GOOGLE_CLIENT_SECRET=
NEXTAUTH_URL=                  # Production URL e.g. https://glowdesk.vercel.app

# ── Web Push (VAPID) ──────────────────────────────────────────────────────────
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# ── Paystack ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=  # pk_live_xxxx or pk_test_xxxx
PAYSTACK_SECRET_KEY=              # sk_live_xxxx or sk_test_xxxx

# ── Cron security ─────────────────────────────────────────────────────────────
CRON_SECRET=                   # Random secret — match value in Vercel dashboard

# ── SMTP — Email notifications ────────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=                     # GlowDesk <no-reply@glowdesk.app>

# ── WhatsApp via Railway (optional) ───────────────────────────────────────────
RAILWAY_WHATSAPP_URL=          # https://your-railway-app.up.railway.app
RAILWAY_WHATSAPP_SESSION=default

# ── Booking app URL (shown in dashboard) ──────────────────────────────────────
NEXT_PUBLIC_BOOKING_APP_URL=   # https://book.glowdesk.app
